# Firebase Configuration
# Get these from Firebase Console -> Project settings -> General -> Your apps -> Web app config

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Optional internal webhook used by api/internal/sync.js
INTERNAL_WEBHOOK_SECRET=your-shared-secret

# Instructions:
# 1. Copy this file to .env
# 2. Replace the values with your actual Firebase web app config
# 3. Never commit the .env file to Git
